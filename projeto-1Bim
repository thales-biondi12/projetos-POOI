alunoscima = 0
alunosbaixo = 0
todasmedias = 0
maiormedia = 0
menormedia = 0
primeiramedia = 0
ultimamedia = 0

print("=" * 60)
print("     SISTEMA DE DESEMPENHO FINAL DOS ALUNOS")
print("=" * 60)

numalunos = int(input("\nDigite o total de estudantes na turma: "))

while numalunos <= 0:
    print("\n Valor inválido!")
    numalunos = int(input("Digite novamente o total de alunos: "))

numdiciplina = int(input("\nDigite o número de disciplinas: "))

while numdiciplina < 0:
    print("[ERRO] Valor inválido!")
    numdiciplina = int(input("Digite novamente o número de disciplinas: "))


print("\n" + "=" * 60)

for x in range(1, numalunos + 1):
    print(f"\n>>> ALUNO {x}")
    print("-" * 30)

    notasomada = 0

    for y in range(1, numdiciplina + 1):
        nota = float(input(f"Nota da matéria {y}: "))

        while nota < 0 or nota > 10:
            print("A nota deve estar entre 0 e 10!")
            nota = float(input(f"Nota da matéria {y}: "))

        notasomada += nota

    media = notasomada / numdiciplina
    todasmedias += media

    print(f"\nMédia do aluno: {media:.2f}")

    if media >= 6:
        print("Status: APROVADO")
        alunoscima += 1
    else:
        print("Status: REPROVADO")
        alunosbaixo += 1

    if maiormedia == 0:
        maiormedia = media
        menormedia = media
    else:
        if media > maiormedia:
            maiormedia = media

        if media < menormedia:
            menormedia = media

    if x == 1:
        primeiramedia = media

    if x == numalunos:
        ultimamedia = media


todasmedias = todasmedias / numalunos

print("\n" + "=" * 60)
print("               ANÁLISE DA TURMA")
print("=" * 60)

if todasmedias < 5 or menormedia < 3:
    print("\n>> Desempenho insuficiente!")

elif ultimamedia > primeiramedia and todasmedias >= 7:
    print("\n>> Desempenho consistente e positivo!")

elif ultimamedia < primeiramedia and todasmedias < 5:
    print("\n>> Houve queda no desempenho da turma!")

elif ultimamedia == primeiramedia:
    print("\n>> Desempenho equilibrado!")

else:
    print("\n>> Desempenho irregular!")


print("\n" + "=" * 60)
print("                 RESULTADOS")
print("=" * 60)

print(f"Média geral da turma: {todasmedias:.2f}")
print(f"Alunos aprovados: {alunoscima}")
print(f"Alunos reprovados: {alunosbaixo}")
print(f"Menor média: {menormedia:.2f}")
print(f"Maior média: {maiormedia:.2f}")

print("=" * 60)
